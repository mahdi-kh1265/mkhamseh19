---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mahdi Khamseh">
  <h1 class="home-name">Mahdi Khamseh</h1>
  <div class="home-links">
    <a href="https://github.com/mahdi-kh1265" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
      <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
    </a>
    <a href="mailto:khams008@umn.edu" aria-label="Email">
      <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
    </a>
    <span class="home-location">| Minneapolis, MN</span>
  </div>

  <p class="home-epigraph">“How many kingdoms know us not!” — Pascal</p>

  <div class="home-grid">
    <div class="home-text" style="margin-top: 2em;">
      <p>
        I am a physics and electrical engineering student at the University of Minnesota, particularly interested in the scalable control of Rydberg-atom quantum systems, microwave photonics, and integrated circuits for quantum sensing and precision metrology. I currently work at <a href="https://posmphotonics.org/index.html" target="_blank" rel="noopener noreferrer">POSM</a> and the MTP Lab.
      </p>
    </div>

    <div class="home-photo-col">
      <img src="/images/mahdiboyfriends-16.JPG" alt="Mahdi Khamseh" class="home-photo" />
    </div>
  </div>

  <div class="home-grid" style="margin-top: -16em;">
    <div class="home-photo-col">
      <img src="/images/IMG_5776.jpg" alt="Second Image" class="home-photo" style="width: 480px;" />
    </div>
    <div class="home-text" style="margin-top: 18em; padding-left: 2em;">
      <p>
        Outside of the lab, I write poetry and prose, play guitar, and practice calligraphy. I like old films where very little happens, songs that sound like they were recorded in the wrong room, books with suspicious underlining, and people who become briefly unbearable when explaining something they love.
      </p>
    </div>
  </div>

  <!-- optional home scraps area for later -->
</BaseLayout>
