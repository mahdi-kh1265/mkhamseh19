---
// MuseForm — six word inputs + run button
// Client-side JS handles the Blob/new-tab output
---

<div class="muse-section">
  <p class="muse-title">stochastic muse</p>
  <p class="muse-desc">
    Give the machine six words.<br />
    It will return three lines.
  </p>
  <form id="muse-form" autocomplete="off">
    <div class="muse-grid">
      <input type="text" name="w1" aria-label="Word 1" maxlength="40" />
      <input type="text" name="w2" aria-label="Word 2" maxlength="40" />
      <input type="text" name="w3" aria-label="Word 3" maxlength="40" />
      <input type="text" name="w4" aria-label="Word 4" maxlength="40" />
      <input type="text" name="w5" aria-label="Word 5" maxlength="40" />
      <input type="text" name="w6" aria-label="Word 6" maxlength="40" />
    </div>
    <button type="submit">run</button>
  </form>
</div>

<script>
  /**
   * Placeholder poem generator.
   * Later this will call the stochastic-muse API.
   */
  async function generateMusePoem(words: string[]): Promise<string[]> {
    // Placeholder: shuffle and recombine input words into three lines
    const pool = words.filter(w => w.trim().length > 0);
    if (pool.length === 0) {
      return ['give me words', 'and I will give you', 'something back'];
    }

    // Simple deterministic-ish recombination
    const shuffle = (arr: string[]) => {
      const a = [...arr];
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    };

    const s = shuffle(pool);
    const thirds = Math.ceil(s.length / 3);
    return [
      s.slice(0, thirds).join(' '),
      s.slice(thirds, thirds * 2).join(' '),
      s.slice(thirds * 2).join(' ') || s[0],
    ];
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  const form = document.getElementById('muse-form') as HTMLFormElement;
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const inputs = form.querySelectorAll('input[type="text"]');
    const words: string[] = [];
    inputs.forEach((input) => {
      words.push((input as HTMLInputElement).value);
    });

    const lines = await generateMusePoem(words);

    const safeLines = lines.map(l => escapeHtml(l));

    const html = `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>poem</title>
<style>
body {
  background: #f1ede1;
  color: #16130f;
  font-family: Georgia, "Times New Roman", Times, serif;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  margin: 0;
  padding: 20px;
}
.poem {
  text-align: left;
  line-height: 2;
  font-size: 18px;
}
</style>
</head>
<body>
<div class="poem">
${safeLines.map(l => `<p>${l}</p>`).join('\n')}
</div>
</body>
</html>`;

    const blob = new Blob([html], { type: 'text/html' });
    const url = URL.createObjectURL(blob);
    const w = window.open(url, '_blank');
    // Revoke after a short delay to allow the page to load
    setTimeout(() => URL.revokeObjectURL(url), 5000);
  });
</script>
